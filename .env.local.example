# Sanity CMS Configuration
# Create a project at https://www.sanity.io/manage and fill these in:
NEXT_PUBLIC_SANITY_PROJECT_ID="your-project-id"
NEXT_PUBLIC_SANITY_DATASET="production"

# Generate an API token at https://www.sanity.io/manage -> API -> Tokens
# Required for the migration script and revalidation webhook
SANITY_API_TOKEN="your-api-token"

# Revalidation secret - set to any random string, then use the same value
# when configuring the Sanity webhook that triggers on-demand revalidation
SANITY_REVALIDATE_SECRET="your-random-secret"
